{
  "name": "fql-analyzer",
  "version": "0.2.12",
  "description": "A library for FQL that provides autocompletions.",
  "repository": "your repo url",
  "author": "Fauna",
  "private": true,
  "type": "module",
  "dependencies": {
    "cross-fetch": "^3.1.6"
  },
  "devDependencies": {
    "@types/jest": "~29.5.2",
    "@types/node": "~20.2.5",
    "@typescript-eslint/eslint-plugin": "~5.59.9",
    "@typescript-eslint/parser": "~5.59.9",
    "esbuild": "^0.18.4",
    "eslint": "~8.42.0",
    "eslint-plugin-jest": "~27.2.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-tsdoc": "~0.2.17",
    "jest": "~29.5.0",
    "prettier": "~2.8.8",
    "pretty-quick": "~3.1.3",
    "ts-jest": "~29.1.0",
    "typescript": "~5.0.4"
  },
  "main": "./build/node/index.cjs",
  "browser": "./build/browser/index.js",
  "types": "./build/ts/index.d.ts",
  "scripts": {
    "check": "tsc --noEmit",
    "build:scala": "cd ../../.. && sbt -Dsbt.supershell=false 'fqlJS / fullLinkJS' && cd - && mkdir -p build/scala && yarn copy:scala",
    "copy:scala": "cp ../js/target/scala-2.13/fql-opt/* build/scala/",
    "build:browser": "esbuild src/index.ts --bundle --platform=browser --format=esm --outfile=build/browser/index.js",
    "build:node": "esbuild src/index.ts --bundle --platform=node --outfile=build/node/index.cjs",
    "build:types": "tsc --emitDeclarationOnly --declaration true > /dev/null; mv build/ts/src/* build/ts && rm -r build/ts/src",
    "build": "yarn build:scala && yarn run check && yarn build:browser && yarn build:node && yarn build:types",
    "start": "node build/ts/src/index.js",
    "lint": "eslint \"{src,test}/**/*.{ts,tsx}\"",
    "test": "node --experimental-vm-modules $(yarn bin jest)",
    "clean": "rm -r build"
  }
}
